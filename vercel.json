{
  "version": 2,
  "builds": [
    {
      "src": "real_estate_backend/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "real_estate_backend/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "real_estate_backend/wsgi.py"
    },
    {
      "src": "/media/(.*)",
      "dest": "real_estate_backend/wsgi.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
